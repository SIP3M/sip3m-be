generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  ADMIN_VERIFIED
  UNDER_REVIEW
  REVISION
  ACCEPTED
  REJECTED
}

enum PengabdianStatus {
  SEDANG_BERJALAN
  PENDING
  SELESAI
}

model proposals {
  id                     Int            @id @default(autoincrement())
  title                  String         @db.VarChar(255)
  lead_researcher_id     Int            @db.Integer
  faculty                String?        @db.VarChar(100)
  funding_request_amount Float?
  status                 ProposalStatus @default(DRAFT)

  skema              String? @db.VarChar(100)
  proposal_file_path String? @db.VarChar(255)
  rab_file_path      String? @db.VarChar(255)

  submitted_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user    users             @relation(fields: [lead_researcher_id], references: [id])
  reviews ProposalReviews[]
  reviewers ProposalReviewers[]
  pengabdianProject PengabdianProjects[]

  @@index([lead_researcher_id])
  @@index([status])
}

model ProposalReviews {
  id          Int            @id @default(autoincrement())
  proposal_id Int
  reviewer_id Int 
  status      ProposalStatus 
  notes       String?        @db.Text
  created_at  DateTime       @default(now())

  proposal proposals @relation(fields: [proposal_id], references: [id])
  reviewer users     @relation(fields: [reviewer_id], references: [id])
}

model Notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  message    String   @db.Text 
  is_read    Boolean  @default(false) 
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model roles {
  id    Int     @id @default(autoincrement())
  roles String  @unique(map: "roles_name_key") @db.VarChar(50)
  users users[]
}

model schema_migrations {
  version BigInt  @id
  dirty   Boolean
}

model users {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  email         String  @unique @db.VarChar(100)
  username      String? @unique @db.VarChar(50)
  password_hash String
  role_id       Int

  nidn_nip      String? @unique @db.VarChar(30)
  fakultas      String? @db.VarChar(100)
  program_studi String? @db.VarChar(100)

  tempat_lahir  String?   @db.VarChar(100)
  tanggal_lahir DateTime? @db.Date
  jenis_kelamin String?   @db.VarChar(15)
  alamat        String?   @db.Text
  nomor_hp      String?   @db.VarChar(20)

  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  roles      roles     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  proposals proposals[]

  instansi          String?           @db.VarChar(100)
  bidang_keahlian   String?           @db.VarChar(100)
  pengalaman_review String?           @db.Text
  cv_path           String?           @db.VarChar(255)
  proposalReviews   ProposalReviews[]
  notifications     Notifications[]
  reviewers ProposalReviewers[]

  @@index([role_id])
}

model ProposalReviewers {
  id          Int       @id @default(autoincrement())
  proposal_id Int
  reviewer_id Int
  created_at  DateTime  @default(now())

  proposal    proposals @relation(fields: [proposal_id], references: [id])
  reviewer    users     @relation(fields: [reviewer_id], references: [id])

  @@unique([proposal_id, reviewer_id]) 
}

model PengabdianProjects {
  id          Int                 @id @default(autoincrement())
  proposal_id Int              @unique
  status      PengabdianStatus     @default(PENDING)
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt

  proposal proposals @relation(fields: [proposal_id], references: [id])
}