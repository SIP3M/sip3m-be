generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatusPencairanDana {
  DISETUJUI
  MENUNGGU_PERSETUJUAN
  TERCAIRKAN
  DITOLAK
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  ADMIN_VERIFIED
  UNDER_REVIEW
  REVISION
  ACCEPTED
  REJECTED
}

enum PengabdianStatus {
  SEDANG_BERJALAN
  PENDING
  SELESAI
}

enum PengabdianMilestoneStatus {
  PENDING
  ONGOING
  COMPLETED
  OVERDUE
}

enum PengabdianDocumentType {
  DOKUMEN_KONTRAK
  LAPORAN_KEMAJUAN_1
  LAPORAN_KEMAJUAN_2
  LAPORAN_AKHIR
  LOGBOOK_KEGIATAN
  BUKTI_PENGGUNAAN_ANGGARAN
  LAINNYA
}

enum DocumentVerificationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model proposals {
  id                     Int            @id @default(autoincrement())
  title                  String         @db.VarChar(255)
  lead_researcher_id     Int            @db.Integer
  faculty                String?        @db.VarChar(100)
  funding_request_amount Int            @db.Integer
  status                 ProposalStatus @default(DRAFT)

  skema              String? @db.VarChar(100)
  proposal_file_path String? @db.VarChar(255)
  rab_file_path      String? @db.VarChar(255)

  submitted_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user    users             @relation(fields: [lead_researcher_id], references: [id])
  reviews ProposalReviews[]
  reviewers ProposalReviewers[]
  pengabdianProject PengabdianProjects?

  @@index([lead_researcher_id])
  @@index([status])
}

model ProposalReviews {
  id          Int            @id @default(autoincrement())
  proposal_id Int
  reviewer_id Int 
  status      ProposalStatus 
  notes       String?        @db.Text
  created_at  DateTime       @default(now())

  // perhitungan nilai
  score_perumusan   Float? 
  score_tinjauan  Float? 
  score_metode    Float? 
  score_anggaran   Float? 
  score_luaran      Float? 
  total_score  Float? 
  kekuatan_proposal String? @db.Text
  kelemahan_proposal String? @db.Text
  rekomendasi_akhir  String? @db.VarChar(50)

  proposal proposals @relation(fields: [proposal_id], references: [id])
  reviewer users     @relation(fields: [reviewer_id], references: [id])
}

model Notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  message    String   @db.Text 
  is_read    Boolean  @default(false) 
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model roles {
  id    Int     @id @default(autoincrement())
  roles String  @unique(map: "roles_name_key") @db.VarChar(50)
  users users[]
}

model schema_migrations {
  version BigInt  @id
  dirty   Boolean
}

model users {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  email         String  @unique @db.VarChar(100)
  username      String? @unique @db.VarChar(50)
  password_hash String
  role_id       Int

  nidn_nip      String? @unique @db.VarChar(30)
  fakultas      String? @db.VarChar(100)
  program_studi String? @db.VarChar(100)

  tempat_lahir  String?   @db.VarChar(100)
  tanggal_lahir DateTime? @db.Date
  jenis_kelamin String?   @db.VarChar(15)
  alamat        String?   @db.Text
  nomor_hp      String?   @db.VarChar(20)

  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  roles      roles     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  proposals proposals[]

  instansi          String?           @db.VarChar(100)
  bidang_keahlian   String?           @db.VarChar(100)
  pengalaman_review String?           @db.Text
  cv_path           String?           @db.VarChar(255)
  proposalReviews   ProposalReviews[]
  notifications     Notifications[]
  reviewers ProposalReviewers[]
  pengabdianDocumentsUploaded PengabdianDocuments[] @relation("UploadedByUser")

  @@index([role_id])
}

model ProposalReviewers {
  id          Int       @id @default(autoincrement())
  proposal_id Int
  reviewer_id Int
  created_at  DateTime  @default(now())

  proposal    proposals @relation(fields: [proposal_id], references: [id])
  reviewer    users     @relation(fields: [reviewer_id], references: [id])

  @@unique([proposal_id, reviewer_id]) 
}

model PengabdianProjects {
  id               Int              @id @default(autoincrement())
  proposal_id      Int              @unique
  project_code     String?          @unique @db.VarChar(30)
  title            String?          @db.VarChar(255)
  summary          String?          @db.Text
  start_date       DateTime?        @db.Date
  end_date         DateTime?        @db.Date
  overall_progress Int              @default(0)
  status           PengabdianStatus @default(PENDING)
  is_archived      Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  disbursement_status StatusPencairanDana @default(MENUNGGU_PERSETUJUAN)
  realized_amount     Int?               @default(0) 
  disbursed_at        DateTime?          

  proposal proposals @relation(fields: [proposal_id], references: [id])

  milestones PengabdianMilestones[]
  documents  PengabdianDocuments[]

  @@index([status])
  @@index([is_archived])
}

model PengabdianMilestones {
  id                Int                       @id @default(autoincrement())
  project_id        Int
  title             String                    @db.VarChar(255)
  description       String?                   @db.Text
  sequence          Int
  target_percentage Int                       @default(0)
  due_date          DateTime?                 @db.Date
  status            PengabdianMilestoneStatus @default(PENDING)
  completed_at      DateTime?
  created_at        DateTime                  @default(now())
  updated_at        DateTime                  @updatedAt

  project PengabdianProjects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  documents PengabdianDocuments[]

  @@unique([project_id, sequence])
  @@index([project_id])
  @@index([status])
}

model PengabdianDocuments {
  id                  Int                        @id @default(autoincrement())
  project_id          Int
  milestone_id        Int?
  document_type       PengabdianDocumentType
  title               String?                    @db.VarChar(255)
  file_path           String                     @db.VarChar(500)
  file_size           Int?
  mime_type           String?                    @db.VarChar(100)
  verification_status DocumentVerificationStatus @default(PENDING)
  verification_notes  String?                    @db.Text
  uploaded_by         Int
  uploaded_at         DateTime                   @default(now())

  project    PengabdianProjects   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  milestone  PengabdianMilestones? @relation(fields: [milestone_id], references: [id], onDelete: SetNull)
  uploader   users                @relation("UploadedByUser", fields: [uploaded_by], references: [id])

  @@index([project_id])
  @@index([milestone_id])
  @@index([document_type])
  @@index([verification_status])
}
